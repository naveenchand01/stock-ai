# ===============================================
# ROOT .GITIGNORE
# ===============================================
# This file covers the entire project
# Specific ignores for frontend/backend in their respective folders

# ===============================================
# ENVIRONMENT VARIABLES (SENSITIVE!)
# ===============================================
# Frontend .env (in root or frontend/)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backend .env (contains API keys!)
backend/.env
backend/.env.local
backend/.env.*.local

# ===============================================
# DEPENDENCIES
# ===============================================
# Frontend dependencies
node_modules/
frontend/node_modules/
bun.lockb
frontend/bun.lockb

# Backend dependencies
backend/node_modules/

# ===============================================
# BUILD OUTPUT
# ===============================================
# Frontend build (Vite)
dist/
dist-ssr/
frontend/dist/
frontend/build/
*.tsbuildinfo

# Backend build (TypeScript)
backend/dist/
backend/build/

# ===============================================
# LOGS
# ===============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
backend/*.log

# ===============================================
# CACHE & TEMPORARY FILES
# ===============================================
.cache/
.vite/
*.local
*.tmp

# ===============================================
# IDEs & EDITORS
# ===============================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj*
*.sln

# ===============================================
# OS FILES
# ===============================================
.DS_Store
Thumbs.db

# ===============================================
# TESTING
# ===============================================
coverage/
.nyc_output/

# ===============================================
# MISC
# ===============================================
.pnp
.pnp.js

# ===============================================
# ML Data & Models
# ===============================================
backend/ml_service/models/*.pth
backend/ml_service/models/*.pkl
backend/ml_service/stock_data/*.csv
