# ===============================================
# FRONTEND ENVIRONMENT VARIABLES - EXAMPLE
# ===============================================
# Copy this file to .env and fill in your Firebase config
# All frontend .env vars MUST start with VITE_ prefix
# ℹ️ These values are PUBLIC (exposed to browser)

# ===============================================
# FIREBASE CONFIGURATION (FRONTEND)
# ===============================================
# Get from: Firebase Console → Project Settings → Your apps → SDK setup
# Follow setup guide: FIREBASE_INTEGRATION.md
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ===============================================
# API ENDPOINTS (FRONTEND)
# ===============================================
# Backend API URL
# Development: http://localhost:3001/api
# Production: https://your-api-domain.com/api
VITE_API_URL=http://localhost:3001/api

# ===============================================
# FEATURE FLAGS (FRONTEND)
# ===============================================
# Enable/disable features
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_VOICE=true
