# ===============================================
# BACKEND ENVIRONMENT VARIABLES - EXAMPLE
# ===============================================
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER commit the real .env file!

# ===============================================
# SERVER CONFIGURATION
# ===============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:8080

# ===============================================
# GOOGLE GEMINI AI API (BACKEND ONLY)
# ===============================================
# Used for: AI chat assistant, market summaries, stock insights
# Get your key: https://makersuite.google.com/app/apikey
# ⚠️ REQUIRED for AI features to work
GEMINI_API_KEY=your_gemini_api_key_here

# ===============================================
# RATE LIMITING & CACHING
# ===============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CACHE_TTL_SECONDS=60
CACHE_CHECK_PERIOD=120

# ===============================================
# EMAIL NOTIFICATIONS (OPTIONAL)
# ===============================================
# Gmail SMTP for sending price alert emails
# Setup: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# ===============================================
# WHATSAPP NOTIFICATIONS (OPTIONAL)
# ===============================================
# Twilio API for WhatsApp messages
# Get credentials: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===============================================
# BROWSER PUSH NOTIFICATIONS (OPTIONAL)
# ===============================================
# Generate keys: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
