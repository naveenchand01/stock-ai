# ===============================================
# BACKEND .GITIGNORE
# ===============================================
# Backend-specific files to ignore

# ===============================================
# ENVIRONMENT VARIABLES (HIGHLY SENSITIVE!)
# ===============================================
# ⚠️ NEVER commit this file! Contains secret API keys:
# - GEMINI_API_KEY (Google AI - $$ charges if leaked)
# - SMTP_USER/SMTP_PASS (Email credentials)
# - TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN (WhatsApp - can incur charges)
# - VAPID_PRIVATE_KEY (Push notifications security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===============================================
# DEPENDENCIES
# ===============================================
node_modules/
.pnp
.pnp.js

# ===============================================
# BUILD OUTPUT
# ===============================================
dist/
build/
*.tsbuildinfo

# ===============================================
# LOGS & RUNTIME DATA
# ===============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# ===============================================
# TESTING & COVERAGE
# ===============================================
coverage/
.nyc_output/
*.lcov

# ===============================================
# CACHE & TEMPORARY FILES
